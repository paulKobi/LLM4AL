digraph LavaCrossing_FSM {
    // Graph attributes
    graph [
        rankdir=LR,
        fontname="Helvetica",
        label="RFC-GW01 Lava Crossing FSM\n(reachable states only; door_status in each node label)",
        labelloc=t,
        fontsize=14,
        splines=true,
        nodesep=0.4,
        ranksep=1.2
    ];
    node [fontname="Helvetica", fontsize=10, shape=ellipse];
    edge [fontname="Helvetica", fontsize=9];

    // Start arrow
    __start__ [shape=point, width=0.15, style=filled, fillcolor=black];
    __start__ -> r2c0_L [style=bold];

    // Node declarations
    GOAL [label="GOAL", shape=doublecircle, style=filled, fillcolor=limegreen, color=darkgreen, fontcolor=white, penwidth=2];
    LAVA [label="LAVA", shape=doublecircle, style=filled, fillcolor=crimson, color=darkred, fontcolor=white, penwidth=2];
    r0c0_L [label="(0,0)\ndoor:LOCKED", style=filled, fillcolor=lightyellow];
    r0c0_U [label="(0,0)\ndoor:UNLOCKED", style=filled, fillcolor=lightblue];
    r0c1_L [label="(0,1)\ndoor:LOCKED", style=filled, fillcolor=lightyellow];
    r0c1_U [label="(0,1)\ndoor:UNLOCKED", style=filled, fillcolor=lightblue];
    r0c3_U [label="(0,3)\ndoor:UNLOCKED", style=filled, fillcolor=lightblue];
    r0c4_U [label="(0,4)\ndoor:UNLOCKED", style=filled, fillcolor=lightblue];
